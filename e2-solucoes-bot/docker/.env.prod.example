# ============================================================================
# E2 Soluções Bot - Environment Variables (PRODUCTION)
# ============================================================================
#
# INSTRUÇÕES:
# 1. Copie este arquivo: cp docker/.env.production.example docker/.env.production
# 2. Preencha TODAS as credenciais obrigatórias
# 3. Configure SSL/TLS e domínios
# 4. NUNCA commite docker/.env.production no git (já está no .gitignore)
# 5. Use secrets manager em produção (AWS Secrets Manager, Vault, etc)
#
# DEPLOYMENT GUIDE: docs/deployment/production/PRODUCTION_DEPLOY_EVOLUTION_API.md
# ============================================================================

# ============================================================================
# DOMAIN & SSL CONFIGURATION (OBRIGATÓRIO)
# ============================================================================
# Domínio principal do projeto
DOMAIN=e2solucoes.com.br

# Subdomínios para cada serviço
N8N_SUBDOMAIN=n8n
EVOLUTION_SUBDOMAIN=whatsapp
TRAEFIK_SUBDOMAIN=traefik

# Email para Let's Encrypt (certificados SSL)
ACME_EMAIL=admin@e2solucoes.com.br

# ============================================================================
# EVOLUTION API - Production Configuration (OBRIGATÓRIO)
# ============================================================================
# Versão: v2.3.7 (production-ready com Issue #1474 fix)
# Issue #1474: Container ignora env_file - requer custom entrypoint

# API Key (mínimo 32 caracteres) - NUNCA exponha publicamente!
# Gerar: openssl rand -hex 32
EVOLUTION_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Database configuration
EVOLUTION_DB=evolution_prod
EVOLUTION_INSTANCE_NAME=e2-bot-production

# Server configuration
EVOLUTION_SERVER_URL=https://whatsapp.e2solucoes.com.br

# Webhook configuration (n8n endpoint)
EVOLUTION_WEBHOOK_URL=https://n8n.e2solucoes.com.br/webhook/whatsapp
EVOLUTION_WEBHOOK_EVENTS=MESSAGE_RECEIVED,MESSAGE_SENT,CONNECTION_UPDATE

# QR Code settings
QRCODE_LIMIT=30
QRCODE_COLOR=#000000

# Session configuration
CONFIG_SESSION_PHONE_CLIENT=E2 Bot Production
CONFIG_SESSION_PHONE_NAME=E2 Soluções

# Log level (production)
LOG_LEVEL=ERROR
LOG_COLOR=false

# Timezone
TIMEZONE=America/Sao_Paulo

# ============================================================================
# POSTGRESQL - Production Database (OBRIGATÓRIO)
# ============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX  # Gerar: openssl rand -base64 32
POSTGRES_DB=e2bot_prod

# Performance tuning (ajustar conforme recursos do servidor)
POSTGRES_MAX_CONNECTIONS=200
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_EFFECTIVE_CACHE_SIZE=1GB
POSTGRES_WORK_MEM=16MB
POSTGRES_MAINTENANCE_WORK_MEM=128MB

# Logging (production)
POSTGRES_LOG_CONNECTIONS=on
POSTGRES_LOG_DISCONNECTIONS=on
POSTGRES_LOG_DURATION=on
POSTGRES_LOG_MIN_DURATION_STATEMENT=1000  # Log queries > 1s

# ============================================================================
# N8N - Workflow Automation (OBRIGATÓRIO)
# ============================================================================
# Basic Auth (proteção do n8n UI)
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX  # Senha forte!

# Encryption key (mínimo 32 caracteres)
# Gerar: openssl rand -hex 32
N8N_ENCRYPTION_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Database connection
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=e2bot_prod
DB_POSTGRESDB_USER=postgres
DB_POSTGRESDB_PASSWORD=${POSTGRES_PASSWORD}

# Webhook configuration
WEBHOOK_URL=https://n8n.e2solucoes.com.br/

# Timezone
GENERIC_TIMEZONE=America/Sao_Paulo

# Execution mode (production)
EXECUTIONS_MODE=queue
EXECUTIONS_TIMEOUT=300
EXECUTIONS_TIMEOUT_MAX=600

# Queue mode (Redis)
QUEUE_BULL_REDIS_HOST=redis
QUEUE_BULL_REDIS_PORT=6379
QUEUE_BULL_REDIS_PASSWORD=${REDIS_PASSWORD}

# Security
N8N_BLOCK_ENV_ACCESS_IN_NODE=true
N8N_TEMPLATES_ENABLED=false
N8N_USER_MANAGEMENT_DISABLED=false

# ============================================================================
# REDIS - Cache & Queue (OBRIGATÓRIO)
# ============================================================================
# Senha Redis (CRÍTICO - sem isso Redis fica exposto!)
# Gerar: openssl rand -base64 32
REDIS_PASSWORD=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Memory configuration
REDIS_MAX_MEMORY=512mb
REDIS_MAX_MEMORY_POLICY=allkeys-lru

# Persistence
REDIS_SAVE_INTERVAL=900 1 300 10 60 10000
REDIS_APPEND_ONLY=yes

# ============================================================================
# TRAEFIK - Reverse Proxy & SSL (OBRIGATÓRIO)
# ============================================================================
# Dashboard configuration
TRAEFIK_DASHBOARD_ENABLED=true
TRAEFIK_DASHBOARD_USER=admin
TRAEFIK_DASHBOARD_PASSWORD=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX  # Senha forte!

# Log level (production)
TRAEFIK_LOG_LEVEL=ERROR
TRAEFIK_ACCESS_LOG=true

# Let's Encrypt (production)
TRAEFIK_ACME_STORAGE=/letsencrypt/acme.json
TRAEFIK_ACME_EMAIL=${ACME_EMAIL}
TRAEFIK_ACME_CA_SERVER=https://acme-v02.api.letsencrypt.org/directory

# Rate limiting (proteção DDoS)
TRAEFIK_RATE_LIMIT_AVERAGE=100
TRAEFIK_RATE_LIMIT_BURST=200

# ============================================================================
# MONITORING - Prometheus & Grafana (OPCIONAL)
# ============================================================================
# Habilitar monitoring stack
MONITORING_ENABLED=true

# Grafana configuration
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX  # Senha forte!
GRAFANA_SECRET_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX  # Gerar: openssl rand -hex 32
GRAFANA_INSTALL_PLUGINS=grafana-clock-panel,grafana-simple-json-datasource

# Prometheus retention
PROMETHEUS_RETENTION_TIME=30d
PROMETHEUS_STORAGE_RETENTION_SIZE=10GB

# ============================================================================
# EMAIL / SMTP - Notifications (OPCIONAL - Configurar se usar WF07)
# ============================================================================
# Gmail App Password (https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=bot@e2solucoes.com.br
SMTP_PASSWORD=XXXX XXXX XXXX XXXX  # Gmail App Password (16 caracteres)
EMAIL_FROM=E2 Soluções Bot <bot@e2solucoes.com.br>

# ============================================================================
# BACKUP CONFIGURATION (RECOMENDADO)
# ============================================================================
# Backup automático (via cron)
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 3 * * *  # 3AM diariamente
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=e2bot-backups  # Se usar AWS S3
BACKUP_S3_REGION=sa-east-1
BACKUP_S3_ACCESS_KEY=XXXXXXXXXXXXXXXXXXXX
BACKUP_S3_SECRET_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ============================================================================
# SECURITY HARDENING (RECOMENDADO)
# ============================================================================
# Fail2Ban configuration
FAIL2BAN_ENABLED=true
FAIL2BAN_MAX_RETRY=5
FAIL2BAN_BAN_TIME=3600  # 1 hora

# UFW Firewall ports (apenas estes liberados)
UFW_ALLOWED_PORTS=80,443,22

# IP Whitelist para admin endpoints (separado por vírgula)
ADMIN_IP_WHITELIST=0.0.0.0/0  # MUDAR para IPs específicos em produção!

# ============================================================================
# HEALTHCHECK CONFIGURATION (RECOMENDADO)
# ============================================================================
HEALTHCHECK_INTERVAL=30s
HEALTHCHECK_TIMEOUT=10s
HEALTHCHECK_RETRIES=3
HEALTHCHECK_START_PERIOD=40s

# ============================================================================
# DESENVOLVIMENTO vs PRODUÇÃO
# ============================================================================
# Environment (NÃO MUDAR - este arquivo é production!)
NODE_ENV=production
DEBUG=false

# ============================================================================
# VALIDAÇÃO RÁPIDA
# ============================================================================
#
# Após configurar todas as variáveis:
#
# 1. Validar sintaxe do .env:
#    grep -E "^[A-Z_]+=" docker/.env.production | wc -l
#    # Deve retornar: ~70 variáveis
#
# 2. Verificar secrets não-vazios:
#    grep "PASSWORD=XXXX" docker/.env.production
#    # Não deve retornar nada! (todos os XXXX devem ser substituídos)
#
# 3. Testar docker-compose:
#    docker-compose -f docker/docker-compose-prd.yml config
#    # Deve retornar configuração completa sem erros
#
# 4. Validar SSL/TLS:
#    curl -I https://n8n.e2solucoes.com.br
#    # Deve retornar: HTTP/2 200 (com certificado válido)
#
# ============================================================================
